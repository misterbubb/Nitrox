<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:Nitrox.Launcher.Models.Converters"
             xmlns:models="clr-namespace:Nitrox.Launcher.Models.Design"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Nitrox.Launcher.Views.Controls.ServerStatusControl"
             x:DataType="models:ServerEntry">
    <StackPanel Orientation="Horizontal" Spacing="12">
        <StackPanel.Styles>
            <Style Selector="Ellipse">
                <Setter Property="Height" Value="6" />
                <Setter Property="Width" Value="6" />
            </Style>
            <Style Selector="TextBlock">
                <Setter Property="Opacity" Value="0.5" />
            </Style>
            <Style Selector="TextBlock.online:pointerover">
                <Setter Property="TextDecorations" Value="Underline" />
            </Style>
        </StackPanel.Styles>
        
        <!-- Status indicator -->
        <Panel>
            <!-- Loading state -->
            <StackPanel IsVisible="{Binding IsLoading}" Orientation="Horizontal">
                <Ellipse Fill="{DynamicResource SystemAccentColor}" Margin="0,0,6,0" />
                <TextBlock Text="{Binding LoadingStage, FallbackValue='Loading...'}" />
            </StackPanel>
            
            <!-- Online state (only when not loading) -->
            <StackPanel Orientation="Horizontal">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="IsOnline" />
                        <Binding Path="!IsLoading" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Ellipse Fill="{DynamicResource BrandOnColor}" Margin="0,0,6,0" />
                <TextBlock Text="Online" />
            </StackPanel>
            
            <!-- Offline state (only when not loading and not online) -->
            <StackPanel Orientation="Horizontal">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="!IsOnline" />
                        <Binding Path="!IsLoading" />
                    </MultiBinding>
                </StackPanel.IsVisible>
                <Ellipse Fill="{DynamicResource BrandOffColor}" Margin="0,0,6,0" />
                <TextBlock Text="Offline" />
            </StackPanel>
        </Panel>
        
        <!-- Game mode (hidden when loading) -->
        <TextBlock Text="{Binding GameMode, Converter={converters:ToStringConverter}, FallbackValue=Survival}"
                   IsVisible="{Binding !IsLoading}" />
        
        <!-- Player count (hidden when loading) -->
        <TextBlock TextWrapping="NoWrap" Background="Transparent"
                   Classes.online="{Binding IsOnline, FallbackValue=False}"
                   ToolTip.Tip="{Binding PlayerNamesTooltip, FallbackValue=''}"
                   IsVisible="{Binding !IsLoading}">
            <Run Text="{Binding PlayerCount, FallbackValue=0}" />
            <Run Text=" / " />
            <Run Text="{Binding MaxPlayers, FallbackValue=100}" />
            <Run Text=" playing" />
        </TextBlock>
    </StackPanel>
</UserControl>

